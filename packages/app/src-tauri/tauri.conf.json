{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ccm",
  "version": "0.1.0",
  "identifier": "com.oreo.ccm",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "ccm",
        "width": 760,
        "height": 560,
        "resizable": true,
        "visible": true
      },
      {
        "label": "tray",
        "url": "index.html",
        "width": 320,
        "height": 400,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
