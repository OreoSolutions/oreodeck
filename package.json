{
  "name": "oreodeck",
  "version": "0.1.4",
  "description": "Manage multiple isolated Claude Code profiles on macOS",
  "license": "Apache-2.0",
  "repository": "github:OreoSolutions/oreodeck",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bun test packages/core packages/cli",
    "test:contract": "bun test packages/core/src/contract-fixtures.test.ts && cargo test --manifest-path packages/core-rs/Cargo.toml contract",
    "typecheck": "tsc --noEmit",
    "lint": "cargo clippy --manifest-path packages/core-rs/Cargo.toml --all-targets -- -D warnings",
    "fmt:check": "cargo fmt --manifest-path packages/core-rs/Cargo.toml --check",
    "build": "bash scripts/build.sh",
    "build:cli": "bun build packages/cli/src/index.ts --compile --outfile dist/oreodeck && bun build packages/cli/src/index.ts --compile --outfile dist/ord",
    "build:app": "bash packages/app/scripts/bundle.sh dist/OreoDeck.app",
    "sign": "bash scripts/sign.sh",
    "notarize": "bash scripts/notarize.sh",
    "package:release": "bash scripts/package-release.sh",
    "test:app": "bash packages/app/scripts/generate.sh && swift test --package-path packages/app"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.11"
  }
}
